# Copie ce fichier en ".env" et remplis-le. Ne le commite jamais dans git.

# Ton identifiant CESI (email pro), ex: prenom.nom@viacesi.fr
CESI_USERNAME=

# Ton mot de passe CESI (en clair ici, donc protège bien ce fichier :
# chmod 600 .env, et si possible utilise un coffre-fort de secrets sur ton VPS
# plutot qu'un fichier en clair pour un usage long terme).
CESI_PASSWORD=

# Ton code personne CESI, visible dans l'URL de l'API sur la page
# "Mon emploi du temps" (ouvre les devtools réseau, cherche /api/seance/all,
# le paramètre codePersonne=XXXXXXX). Le tien est 2426023.
CESI_CODE_PERSONNE=
